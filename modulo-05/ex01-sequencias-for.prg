FUNCTION Main()

    LOCAL nCont

    ? "Sequência de 1 a 100"

    FOR nCont := 1 TO 100
        ? nCont
    NEXT

    ? "Sequência de -50 a 50"

    FOR nCont := -50 TO 50
        ? nCont
    NEXT

    ? "Sequência de 80 a 5"

    FOR nCont := 80 TO 5 STEP -1
        ? nCont
    NEXT

    ? "Fim do programa."

RETURN NIL